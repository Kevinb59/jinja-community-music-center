# Page don (optionnel)
# VITE_DONATION_URL=https://example.com/donation

# Google Apps Script — à définir sur Vercel / en local (.env non versionné)
# Noms recommandés (lus au build par vite.config.js, pas besoin du préfixe VITE_)
# GAS_URL_CONTACT=https://script.google.com/macros/s/VOTRE_ID/exec
# GAS_URL_MATERIAL=https://script.google.com/macros/s/VOTRE_ID/exec

# Compatibilité : les anciennes variables VITE_GAS_* fonctionnent encore
# VITE_GAS_CONTACT_URL=https://script.google.com/macros/s/VOTRE_ID/exec
# VITE_GAS_MATERIAL_URL=https://script.google.com/macros/s/VOTRE_ID/exec

# Pages dans public/ (boutique, etc.) : éditer public/js/config.js ou prévoir une étape de déploiement séparée
